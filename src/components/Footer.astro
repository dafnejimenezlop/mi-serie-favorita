---
// src/components/Footer.astro

const currentYear = new Date().getFullYear();

// Enlaces de la antigua web, actualizados para el nuevo diseño
const paginasLinks = [
  { href: '/#inicio', label: 'Inicio' },
  { href: '#resumen', label: 'Resumen Temporadas' },
  { href: '/#ciclos', label: 'Ciclos del Tiempo' },
  { href: '/#personajes', label: 'Familias / Personajes' },
  { href: '/#teorias', label: 'Teorías' },
];

const proyectoLinks = [
  {
    href: 'https://www.netflix.com/title/80100172',
    label: 'Ver DARK en Netflix',
    target: '_blank',
  },
  { href: '#', label: 'Preguntas Frecuentes (FAQ)' },
  { href: 'mailto:contacto@winden.fan', label: 'Reportar Paradoja / Contacto' },
];
---

<footer
  class="relative mt-auto py-16 md:py-20 bg-stone-900 dark:bg-[#0a0a0a]/90 backdrop-blur-md border-t border-stone-700 dark:border-stone-800 transition-colors duration-500 overflow-hidden"
>
  <svg
    class="absolute -right-24 -bottom-24 w-[500px] h-[500px] text-stone-100 opacity-[0.03] dark:opacity-[0.02] pointer-events-none transform rotate-12"
    viewBox="0 0 100 100"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
  >
    <circle cx="50" cy="40" r="28"></circle>
    <circle cx="35" cy="65" r="28"></circle>
    <circle cx="65" cy="65" r="28"></circle>
  </svg>

  <div class="container mx-auto px-6 relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-8 items-start">
      <div class="md:col-span-4 space-y-6">
        <a href="/" class="flex-shrink-0 inline-block">
          <img
            src="/prueba.png"
            alt="Dark Logo"
            class="h-10 md:h-14 w-auto object-contain transition-transform hover:scale-105 filter drop-shadow-[0_0_8px_rgba(255,255,255,0.1)]"
          />
        </a>
        <p
          class="text-sm md:text-base text-stone-200 font-cinzel font-bold tracking-[0.2em]"
        >
          SIC MUNDUS CREATUS EST.
        </p>
        <div class="h-px w-24 bg-amber-500 transition-colors"></div>
        <p
          class="text-xs md:text-sm text-stone-400 font-mono tracking-wider pt-2 italic leading-relaxed"
        >
          "El final es el principio. Y el principio es el fin."
        </p>
      </div>

      <div class="md:col-span-3 md:pl-10">
        <h4
          class="font-cinzel text-amber-500 uppercase tracking-[0.3em] font-bold text-lg mb-6"
        >
          Páginas
        </h4>
        <ul class="space-y-4">
          {
            paginasLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm md:text-base text-stone-400 hover:text-amber-400 transition-colors tracking-wide font-light flex items-center group"
                >
                  <span class="w-0 h-px bg-amber-500 mr-0 group-hover:w-3 group-hover:mr-2 transition-all duration-300" />
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-3 md:pl-8">
        <h4
          class="font-cinzel text-amber-500 uppercase tracking-[0.3em] font-bold text-lg mb-6"
        >
          Enlaces
        </h4>
        <ul class="space-y-4">
          {
            proyectoLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.target}
                  class="text-sm md:text-base text-stone-400 hover:text-amber-400 transition-colors tracking-wide font-light flex items-center group"
                >
                  <span class="w-0 h-px bg-amber-500 mr-0 group-hover:w-3 group-hover:mr-2 transition-all duration-300" />
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div
        class="md:col-span-2 flex md:flex-col items-center md:items-end justify-center md:justify-start space-x-6 md:space-x-0 md:space-y-6 pt-4 md:pt-0"
      >
        <a
          href="#"
          class="p-3 bg-stone-800 dark:bg-stone-900 border border-stone-700 dark:border-stone-800 rounded-full hover:bg-black hover:border-amber-500/50 text-stone-400 hover:text-amber-500 shadow-lg group"
          aria-label="Instagram"
        >
          <svg
            class="w-5 h-5 md:w-6 md:h-6 transform group-hover:scale-110 transition-transform"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.919-.058-1.265-.069-1.646-.069-4.849 0-3.204.012-3.583.069-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28-.073-1.689-.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path></svg
          >
        </a>
        <a
          href="#"
          class="p-3 bg-stone-800 dark:bg-stone-900 border border-stone-700 dark:border-stone-800 rounded-full hover:bg-black hover:border-amber-500/50 text-stone-400 hover:text-amber-500 shadow-lg group"
          aria-label="X (Twitter)"
        >
          <svg
            class="w-5 h-5 md:w-6 md:h-6 transform group-hover:scale-110 transition-transform"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path></svg
          >
        </a>
        <a
          href="#"
          class="p-3 bg-stone-800 dark:bg-stone-900 border border-stone-700 dark:border-stone-800 rounded-full hover:bg-black hover:border-amber-500/50 text-stone-400 hover:text-amber-500 shadow-lg group"
          aria-label="YouTube"
        >
          <svg
            class="w-5 h-5 md:w-6 md:h-6 transform group-hover:scale-110 transition-transform"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            ></path></svg
          >
        </a>
      </div>
    </div>

    <div
      class="mt-16 md:mt-20 pt-8 border-t border-stone-700 dark:border-stone-800 space-y-4"
    >
      <div
        class="flex flex-col md:flex-row items-center md:justify-between space-y-4 md:space-y-0 text-center md:text-left"
      >
        <p
          class="text-[10px] md:text-xs text-stone-400 font-mono tracking-[0.2em] md:tracking-[0.3em] uppercase"
        >
          2017 <span class="text-amber-500 px-1">⭢</span> 2020 <span
            class="text-amber-500 px-1">⭢</span
          >
          {currentYear}
          <span class="text-amber-500 px-1">⭢</span> ∞ <span
            class="font-light text-stone-500 ml-2">SIC MUNDUS CREATUS EST.</span
          >
        </p>

        <p class="text-xs text-stone-500 tracking-wider">
          Un tributo de fans a <span class="text-stone-300 font-bold">DARK</span
          >. No afiliado con <span class="text-stone-300 font-bold"
            >Netflix</span
          >.
        </p>
      </div>
    </div>
  </div>

  <div
    class="absolute inset-0 bg-amber-900/10 -z-10 blur-3xl rounded-full scale-110 opacity-40 pointer-events-none"
  >
  </div>
</footer>

<style>
  .font-mono {
    font-family:
      ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono',
      'Courier New', monospace;
  }
</style>
