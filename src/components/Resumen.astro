---
// src/components/sections/Resumen.astro
---

<div class="pt-40 md:pt-48 pb-24 relative z-10 w-full min-h-screen">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="text-center space-y-6 mb-12" data-aos="fade-down">
      <h2
        class="text-4xl md:text-6xl font-cinzel text-amber-500 font-bold tracking-[0.2em] drop-shadow-2xl uppercase"
      >
        Resumen
      </h2>
      <p
        class="text-base md:text-lg text-stone-300 font-light leading-relaxed max-w-2xl mx-auto tracking-wide"
      >
        26 episodios. Tres temporadas. Un misterio que inicia desde el capítulo
        piloto y se entrelaza hasta el apocalipsis final.
      </p>
    </div>

    <div
      class="flex items-center justify-center gap-4 mb-16 opacity-80"
      data-aos="zoom-in"
    >
      <div
        class="h-[1px] w-12 md:w-24 bg-gradient-to-r from-transparent to-red-600"
      >
      </div>
      <p
        class="text-red-500 font-mono tracking-widest uppercase text-[10px] md:text-xs font-bold flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
          ></path></svg
        >
        Contiene Spoilers
      </p>
      <div
        class="h-[1px] w-12 md:w-24 bg-gradient-to-l from-transparent to-red-600"
      >
      </div>
    </div>

    <div
      class="flex flex-wrap justify-center gap-2 md:gap-4 mb-16"
      data-aos="fade-up"
    >
      <button
        class="tab-btn active px-6 py-2 rounded font-cinzel font-bold tracking-widest uppercase transition-all duration-300 text-amber-500 border-b-2 border-amber-500 bg-black/40 shadow-[0_4px_20px_rgba(0,0,0,0.5)]"
        data-target="temp1"
      >
        Temporada 1
      </button>
      <button
        class="tab-btn px-6 py-2 rounded font-cinzel font-bold tracking-widest uppercase transition-all duration-300 text-stone-500 border-b-2 border-transparent hover:text-stone-300 hover:bg-black/20"
        data-target="temp2"
      >
        Temporada 2
      </button>
      <button
        class="tab-btn px-6 py-2 rounded font-cinzel font-bold tracking-widest uppercase transition-all duration-300 text-stone-500 border-b-2 border-transparent hover:text-stone-300 hover:bg-black/20"
        data-target="temp3"
      >
        Temporada 3
      </button>
    </div>

    <div class="relative w-full">
      <div id="temp1" class="tab-content block animate-fade-in">
        <div class="flex items-center gap-6 mb-12">
          <h3
            class="text-2xl md:text-4xl font-cinzel text-stone-100 font-bold uppercase tracking-widest whitespace-nowrap"
          >
            El origen
          </h3>
          <div
            class="h-[1px] flex-grow bg-gradient-to-r from-stone-700 to-transparent"
          >
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center mb-24">
          <div
            class="lg:col-span-5 space-y-6 text-stone-300 font-light leading-relaxed text-base md:text-lg"
          >
            <p>
              En el año 2019, Michael Kahnwald decide quitarse la vida y deja
              una misteriosa carta dirigida a Ines, su madre.
            </p>
            <p>
              El pueblo de Winden se estremece con la desaparición de un joven
              llamado Erik. Poco después, durante una noche en el bosque, <span
                class="text-amber-500 font-medium"
                >Mikkel Nielsen desaparece sin dejar rastro</span
              >.
            </p>
            <p>
              Jonas Kahnwald descubrirá que el motivo del suicidio de su padre
              oculta un secreto imposible: Michael Kahnwald es en realidad
              Mikkel, que viajó en el tiempo hasta 1986.
            </p>
          </div>
          <div class="lg:col-span-7">
            <div class="relative group rounded-md overflow-hidden shadow-2xl">
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent z-10 pointer-events-none"
              >
              </div>
              <img
                src="/resumen/temporada1/1.jpg"
                class="w-full object-cover aspect-video transform group-hover:scale-105 transition-transform duration-700"
              />
            </div>
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center mb-24">
          <div class="lg:col-span-7 order-2 lg:order-1">
            <div class="relative group rounded-md overflow-hidden shadow-2xl">
              <div
                class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent z-10 pointer-events-none"
              >
              </div>
              <img
                src="/resumen/temporada1/2.jpg"
                class="w-full object-cover aspect-[21/9] transform group-hover:scale-105 transition-transform duration-700 grayscale hover:grayscale-0"
              />
            </div>
          </div>
          <div
            class="lg:col-span-5 order-1 lg:order-2 space-y-6 text-stone-300 font-light leading-relaxed text-base md:text-lg"
          >
            <p>
              Tres épocas colisionan: <span class="text-amber-500 font-medium"
                >1953, 1986 y 2019</span
              >.
            </p>
            <p>
              Los secretos de las cuatro familias principales quedan al
              descubierto gracias a los viajes por las cuevas de Winden y la
              misteriosa figura del cura Noah.
            </p>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto rounded-md overflow-hidden shadow-2xl bg-black aspect-video border border-stone-800"
        >
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/zmxw7NgsBH4?controls=1"
            allowfullscreen></iframe>
        </div>
      </div>

      <div id="temp2" class="tab-content hidden animate-fade-in">
        <div class="flex items-center gap-6 mb-12">
          <h3
            class="text-2xl md:text-4xl font-cinzel text-stone-100 font-bold uppercase tracking-widest whitespace-nowrap"
          >
            El apocalipsis
          </h3>
          <div
            class="h-[1px] flex-grow bg-gradient-to-r from-stone-700 to-transparent"
          >
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center mb-24">
          <div
            class="lg:col-span-5 space-y-6 text-stone-300 font-light leading-relaxed text-base md:text-lg"
          >
            <p>
              Jonas se encuentra atrapado en el año 2052, sobreviviendo en las
              ruinas de un mundo arrasado por el apocalipsis de 2020.
            </p>
            <p>
              En su intento de regresar y cambiarlo todo, acaba en 1921
              descubriendo a la organización "Sic Mundus", liderada por <span
                class="text-amber-500 font-medium"
                >Adam, quien resulta ser su yo del futuro</span
              >.
            </p>
          </div>
          <div class="lg:col-span-7">
            <div class="relative group rounded-md overflow-hidden shadow-2xl">
              <img
                src="/resumen/temporada2/1.jpg"
                class="w-full object-cover aspect-video transform group-hover:scale-105 transition-transform duration-700"
              />
            </div>
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center mb-24">
          <div class="lg:col-span-7 order-2 lg:order-1">
            <div class="relative group rounded-md overflow-hidden shadow-2xl">
              <img
                src="/resumen/temporada2/2.jpg"
                class="w-full object-cover aspect-[21/9] transform group-hover:scale-105 transition-transform duration-700 grayscale hover:grayscale-0"
              />
            </div>
          </div>
          <div
            class="lg:col-span-5 order-1 lg:order-2 space-y-6 text-stone-300 font-light leading-relaxed text-base md:text-lg"
          >
            <p>
              El fin es inevitable. En los instantes previos a la destrucción de
              Winden, Martha muere frente a Jonas.
            </p>
            <p>
              Justo cuando todo parece perdido, <span
                class="text-amber-500 font-medium">aparece otra Martha</span
              >, revelando que la pregunta ya no es "de qué época eres", sino
              "de qué mundo".
            </p>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto rounded-md overflow-hidden shadow-2xl bg-black aspect-video border border-stone-800"
        >
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/Nghb6pT0ghk?controls=1"
            allowfullscreen></iframe>
        </div>
      </div>

      <div id="temp3" class="tab-content hidden animate-fade-in">
        <div class="flex items-center gap-6 mb-12">
          <h3
            class="text-2xl md:text-4xl font-cinzel text-stone-100 font-bold uppercase tracking-widest whitespace-nowrap"
          >
            El nudo
          </h3>
          <div
            class="h-[1px] flex-grow bg-gradient-to-r from-stone-700 to-transparent"
          >
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center mb-24">
          <div
            class="lg:col-span-5 space-y-6 text-stone-300 font-light leading-relaxed text-base md:text-lg"
          >
            <p>
              Jonas despierta en el año 2019 de un mundo paralelo. En esta
              realidad <span class="text-amber-500 font-medium"
                >él nunca nació</span
              >, pero el ciclo de dolor y desapariciones es exactamente el
              mismo.
            </p>
            <p>
              Comprende que ambos mundos están entrelazados en una guerra
              infinita entre Adam (la luz/oscuridad) y Eva (la Martha del otro
              mundo).
            </p>
          </div>
          <div class="lg:col-span-7">
            <div class="relative group rounded-md overflow-hidden shadow-2xl">
              <img
                src="/resumen/temporada3/2.jpg"
                class="w-full object-cover aspect-video transform group-hover:scale-105 transition-transform duration-700"
              />
            </div>
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center mb-24">
          <div class="lg:col-span-7 order-2 lg:order-1">
            <div class="relative group rounded-md overflow-hidden shadow-2xl">
              <img
                src="/resumen/temporada3/1.jpg"
                class="w-full object-cover aspect-[21/9] transform group-hover:scale-105 transition-transform duration-700 grayscale hover:grayscale-0"
              />
            </div>
          </div>
          <div
            class="lg:col-span-5 order-1 lg:order-2 space-y-6 text-stone-300 font-light leading-relaxed text-base md:text-lg"
          >
            <p>Para romper el nudo, deben encontrar el "Mundo Origen".</p>
            <p>
              El relojero Tannhaus creó la máquina del tiempo para evitar la
              muerte de su familia, dividiendo accidentalmente su mundo original
              en dos realidades llenas de sufrimiento que deben ser borradas de
              la existencia.
            </p>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto rounded-md overflow-hidden shadow-2xl bg-black aspect-video border border-stone-800"
        >
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/z2wPBG-GSJ0?controls=1"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .animate-fade-in {
    animation: fadeIn 0.6s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        contents.forEach((c) => {
          c.classList.remove('block');
          c.classList.add('hidden');
        });
        tabs.forEach((t) => {
          t.classList.remove(
            'text-amber-500',
            'border-amber-500',
            'bg-black/40',
            'shadow-[0_4px_20px_rgba(0,0,0,0.5)]',
          );
          t.classList.add('text-stone-500', 'border-transparent');
        });

        const targetId = tab.getAttribute('data-target');
        document.getElementById(targetId).classList.remove('hidden');
        document.getElementById(targetId).classList.add('block');

        tab.classList.remove('text-stone-500', 'border-transparent');
        tab.classList.add(
          'text-amber-500',
          'border-amber-500',
          'bg-black/40',
          'shadow-[0_4px_20px_rgba(0,0,0,0.5)]',
        );
      });
    });
  });
</script>
