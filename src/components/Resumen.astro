---
// src/components/sections/Resumen.astro
---

<div class="pt-40 md:pt-48 pb-24 relative z-10 w-full min-h-screen">
  <div class="container mx-auto px-6 max-w-6xl">
    <div class="text-center space-y-6 mb-12" data-aos="fade-down">
      <h2
        class="text-4xl md:text-6xl font-cinzel text-amber-600 dark:text-amber-500 font-bold tracking-[0.2em] drop-shadow-lg dark:drop-shadow-2xl uppercase"
      >
        Resumen
      </h2>
      <p
        class="text-base md:text-lg text-stone-700 dark:text-stone-300 font-light leading-relaxed max-w-2xl mx-auto tracking-wide"
      >
        26 episodios. Tres temporadas. Un misterio que inicia desde el capítulo
        piloto y se entrelaza hasta el apocalipsis final.
      </p>
    </div>

    <div
      class="flex items-center justify-center gap-4 mb-16 opacity-80"
      data-aos="zoom-in"
    >
      <div
        class="h-[1px] w-12 md:w-24 bg-gradient-to-r from-transparent to-red-600"
      >
      </div>
      <p
        class="text-red-600 dark:text-red-500 font-mono tracking-widest uppercase text-sm md:text-md font-bold flex items-center gap-2"
      >
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
          ></path></svg
        >
        Contiene Spoilers
      </p>
      <div
        class="h-[1px] w-12 md:w-24 bg-gradient-to-l from-transparent to-red-600"
      >
      </div>
    </div>

    <div
      class="flex flex-wrap justify-center gap-2 md:gap-4 mb-16"
      data-aos="fade-up"
    >
      <button
        class="tab-btn active px-6 py-3 rounded-t-lg font-cinzel font-bold tracking-widest uppercase transition-all duration-300 text-white border-b-2 border-amber-600 dark:border-amber-500 bg-stone-800 dark:bg-[#0a0a0a] shadow-lg"
        data-target="temp1"
      >
        Temporada 1
      </button>
      <button
        class="tab-btn px-6 py-3 rounded-t-lg font-cinzel font-bold tracking-widest uppercase transition-all duration-300 text-stone-500 border-b-2 border-transparent hover:text-stone-700 dark:hover:text-stone-300 hover:bg-stone-300/40 dark:hover:bg-stone-900/40"
        data-target="temp2"
      >
        Temporada 2
      </button>
      <button
        class="tab-btn px-6 py-3 rounded-t-lg font-cinzel font-bold tracking-widest uppercase transition-all duration-300 text-stone-500 border-b-2 border-transparent hover:text-stone-700 dark:hover:text-stone-300 hover:bg-stone-300/40 dark:hover:bg-stone-900/40"
        data-target="temp3"
      >
        Temporada 3
      </button>
    </div>

    <div class="relative w-full">
      <div id="temp1" class="tab-content block animate-fade-in">
        <div class="flex items-center gap-6 mb-12">
          <h3
            class="text-2xl md:text-4xl font-cinzel text-stone-800 dark:text-stone-100 font-bold uppercase tracking-widest whitespace-nowrap"
          >
            El enigma
          </h3>
          <div
            class="h-[1px] flex-grow bg-gradient-to-r from-stone-400 dark:from-stone-700 to-transparent"
          >
          </div>
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800/60 bg-stone-800 dark:bg-[#0a0a0a] mb-12 group"
        >
          <div class="absolute inset-0 md:left-1/3 overflow-hidden z-0">
            <img
              src="/resumen/temporada1/1.jpg"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 opacity-60 md:opacity-100"
            />
          </div>
          <div
            class="absolute inset-0 md:left-1/3 bg-gradient-to-t md:bg-gradient-to-r from-stone-800 via-stone-800/95 dark:from-[#0a0a0a] dark:via-[#0a0a0a]/90 to-transparent pointer-events-none z-0"
          >
          </div>

          <div class="relative z-10 p-8 md:p-16 md:w-2/3 space-y-6">
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              En el año 2019, Michael Kahnwald decide quitarse la vida y deja
              una carta dirigida a Ines, su madre. Jonas, su hijo, queda muy
              marcado después de lo sucedido y trata de recuperarse
              psicológicamente con ayuda de Peter Doppler, su psiquiatra.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Al mismo tiempo, el pueblo de Winden lamenta la desaparición de un
              joven llamado Erik. Ni los vecinos, ni la policía saben lo que ha
              podido ocurrir.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Una noche, mientras Jonas anda con sus amigos Bartosz, Magnus y
              Martha, el hermano pequeño de estos últimos, <span
                class="text-amber-500 font-medium">Mikkel, desaparece</span
              >. A partir de ese momento, el cuerpo de policía de Winden, del
              que el padre de Mikkel forma parte, pone todos sus esfuerzos por
              encontrar al menor con vida.
            </p>
          </div>
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800/60 bg-stone-800 dark:bg-[#0a0a0a] mb-16 group"
        >
          <div class="absolute inset-0 md:w-2/3 overflow-hidden z-0">
            <img
              src="/resumen/temporada1/2.jpg"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 grayscale group-hover:grayscale-0 opacity-50 md:opacity-80"
            />
          </div>
          <div
            class="absolute inset-0 md:w-2/3 bg-gradient-to-t md:bg-gradient-to-l from-stone-800 via-stone-800/95 dark:from-[#0a0a0a] dark:via-[#0a0a0a]/90 to-transparent pointer-events-none z-0"
          >
          </div>

          <div class="relative z-10 p-8 md:p-16 md:w-2/3 md:ml-auto space-y-6">
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Pronto, también aparece un cuerpo de un menor desaparecido en
              1986.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Por su parte, Jonas, en su intento de descubrir el motivo por el
              que su padre se suicidó, realiza un viaje espacio-temporal gracias
              a la ayuda de un misterioso hombre. Entonces descubre que, en
              realidad, su padre es Mikkel Nielsen, que creció bajo el nombre de
              Michael Kahnwald y fue adoptado por su abuela Ines.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              <span class="text-amber-500 font-medium">1953, 1986 y 2019</span> son
              las líneas espacio-temporales a partir de las cuales se va desgranando
              esta temporada. A través de ellas, se descubren los secretos de cada
              una de las familias. Todos ellos tienen algo en común y sus propios
              secretos. Entretanto aparece Noah, un misterioso cura que parece estar
              detrás de los viajes temporales.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Al final de la temporada, Jonas viaja a 2052 y descubre un Winden
              completamente arrasado.
            </p>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto rounded-xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800 bg-black aspect-video"
        >
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/zmxw7NgsBH4?controls=1"
            allowfullscreen></iframe>
        </div>
      </div>

      <div id="temp2" class="tab-content hidden animate-fade-in">
        <div class="flex items-center gap-6 mb-12">
          <h3
            class="text-2xl md:text-4xl font-cinzel text-stone-800 dark:text-stone-100 font-bold uppercase tracking-widest whitespace-nowrap"
          >
            Hacia el apocalipsis
          </h3>
          <div
            class="h-[1px] flex-grow bg-gradient-to-r from-stone-400 dark:from-stone-700 to-transparent"
          >
          </div>
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800/60 bg-stone-800 dark:bg-[#0a0a0a] mb-12 group"
        >
          <div class="absolute inset-0 md:left-1/3 overflow-hidden z-0">
            <img
              src="/resumen/temporada2/1.jpg"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 opacity-60 md:opacity-100"
            />
          </div>
          <div
            class="absolute inset-0 md:left-1/3 bg-gradient-to-t md:bg-gradient-to-r from-stone-800 via-stone-800/95 dark:from-[#0a0a0a] dark:via-[#0a0a0a]/90 to-transparent pointer-events-none z-0"
          >
          </div>

          <div class="relative z-10 p-8 md:p-16 md:w-2/3 space-y-6">
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Jonas se encuentra atrapado en el año 2052. Allí solo están los
              supervivientes del apocalipsis ocurrido en 2020. El joven intenta
              volver a 2019 para poder evitar el desastre. Sin embargo, descubre
              que ya no es posible hacer viajes en el tiempo.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Al final logra escapar de esa época pero acaba inmerso en 1921.
              Entonces conoce a Noah, un misterioso sacerdote que nunca
              envejece.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              También descubre lo que hay detrás de una organización secreta
              llamada "Sic Mundus", cuyo cabecilla se llama <span
                class="text-amber-500 font-medium"
                >Adam (en realidad es Jonas)</span
              >, quien planea un apocalipsis con el fin de que el pasado, el
              presente y el futuro se unan.
            </p>
          </div>
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800/60 bg-stone-800 dark:bg-[#0a0a0a] mb-16 group"
        >
          <div class="absolute inset-0 md:w-2/3 overflow-hidden z-0">
            <img
              src="/resumen/temporada2/2.jpg"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 opacity-50 md:opacity-80 grayscale group-hover:grayscale-0"
            />
          </div>
          <div
            class="absolute inset-0 md:w-2/3 bg-gradient-to-t md:bg-gradient-to-l from-stone-800 via-stone-800/95 dark:from-[#0a0a0a] dark:via-[#0a0a0a]/90 to-transparent pointer-events-none z-0"
          >
          </div>

          <div class="relative z-10 p-8 md:p-16 md:w-2/3 md:ml-auto space-y-6">
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Entretanto Claudia, jefa de la planta nuclear de Winden en 1986,
              intenta parar a la organización e impedir el desastre. Para ello,
              cuenta con la ayuda de Jonas del futuro.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Por otro lado, algunos habitantes de Winden descubren los viajes
              en el tiempo y la identidad de los "viajeros". Jonas se da cuenta
              de que todo lo que ha ocurrido es consecuencia de sus actos. Por
              ello, quiere evitar el apocalipsis de 2020 y cambiar el desarrollo
              de los acontecimientos e impedir la muerte de Martha.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Cuando llega el día del apocalipsis, Martha muere y aparece otra
              muchacha con el mismo aspecto que la joven, la cual procede de <span
                class="text-amber-500 font-medium">otra dimensión</span
              >.
            </p>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto rounded-xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800 bg-black aspect-video"
        >
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/Nghb6pT0ghk?controls=1"
            allowfullscreen></iframe>
        </div>
      </div>

      <div id="temp3" class="tab-content hidden animate-fade-in">
        <div class="flex items-center gap-6 mb-12">
          <h3
            class="text-2xl md:text-4xl font-cinzel text-stone-800 dark:text-stone-100 font-bold uppercase tracking-widest whitespace-nowrap"
          >
            Un nuevo mundo
          </h3>
          <div
            class="h-[1px] flex-grow bg-gradient-to-r from-stone-400 dark:from-stone-700 to-transparent"
          >
          </div>
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800/60 bg-stone-800 dark:bg-[#0a0a0a] mb-12 group"
        >
          <div class="absolute inset-0 md:left-1/3 overflow-hidden z-0">
            <img
              src="/resumen/temporada3/2.jpg"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 opacity-60 md:opacity-100"
            />
          </div>
          <div
            class="absolute inset-0 md:left-1/3 bg-gradient-to-t md:bg-gradient-to-r from-stone-800 via-stone-800/95 dark:from-[#0a0a0a] dark:via-[#0a0a0a]/90 to-transparent pointer-events-none z-0"
          >
          </div>

          <div class="relative z-10 p-8 md:p-16 md:w-2/3 space-y-6">
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Jonas viaja en 2019 a un nuevo Winden, es su pueblo pero se trata
              de un mundo paralelo. En esta nueva realidad <span
                class="text-amber-500 font-medium">él no existe</span
              >, pero la desaparición de uno de los jóvenes del pueblo ha
              marcado también a sus habitantes.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Asimismo, Jonas logra localizar a sus conocidos, entre ellas
              Martha, la cual no es la chica de la que él está enamorado.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              En este Winden, existen cambios con respecto al suyo: Jonas no
              existe y su madre, Hannah, espera un bebé de Ulrich Nielsen. Por
              otro lado, el matrimonio Doppler también está roto y Charlotte
              mantiene una relación clandestina con Ulrich. Esta vez es su hija
              Franziska quien es sorda y no Elisabeth.
            </p>
          </div>
        </div>

        <div
          class="relative w-full rounded-2xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800/60 bg-stone-800 dark:bg-[#0a0a0a] mb-16 group"
        >
          <div class="absolute inset-0 md:w-2/3 overflow-hidden z-0">
            <img
              src="/resumen/temporada3/1.jpg"
              class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-1000 opacity-50 md:opacity-80 grayscale group-hover:grayscale-0"
            />
          </div>
          <div
            class="absolute inset-0 md:w-2/3 bg-gradient-to-t md:bg-gradient-to-l from-stone-800 via-stone-800/95 dark:from-[#0a0a0a] dark:via-[#0a0a0a]/90 to-transparent pointer-events-none z-0"
          >
          </div>

          <div class="relative z-10 p-8 md:p-16 md:w-2/3 md:ml-auto space-y-6">
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Esta temporada abarca tres siglos diferentes. En ella, los
              habitantes de Winden intentan por todos los medios salvar sus
              trágicos destinos y evitar el sufrimiento de sus familiares.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Pero, finalmente, Claudia revela la verdad a Adam, el cual tiene
              la intención de destruir todo lo que abarca los viajes en el
              tiempo. La mujer habla de un mundo origen del cual surgen dos
              mundos interconectados, los cuales fueron creados por el relojero
              Tannhaus con el fin de evitar la muerte de su hijo.
            </p>
            <p
              class="text-stone-300 font-light leading-relaxed text-sm md:text-base"
            >
              Jonas despierta en el año 2019 de un mundo paralelo. En esta
              realidad él nunca nació, pero el ciclo de dolor y desapariciones
              es exactamente el mismo. Comprende que ambos mundos están
              entrelazados en una guerra infinita entre Adam (la luz/oscuridad)
              y Eva (la Martha del otro mundo).
            </p>
          </div>
        </div>

        <div
          class="max-w-5xl mx-auto rounded-xl overflow-hidden shadow-2xl border border-stone-700 dark:border-stone-800 bg-black aspect-video"
        >
          <iframe
            class="w-full h-full"
            src="https://www.youtube.com/embed/z2wPBG-GSJ0?controls=1"
            allowfullscreen></iframe>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .animate-fade-in {
    animation: fadeIn 0.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(15px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');

    function activateTab(tabTargetId) {
      contents.forEach((c) => {
        c.classList.remove('block');
        c.classList.add('hidden');
      });

      // Apagamos todas las pestañas (Diseño inactivo)
      tabs.forEach((t) => {
        t.classList.remove(
          'text-white',
          'border-amber-600',
          'dark:border-amber-500',
          'bg-stone-800',
          'dark:bg-[#0a0a0a]',
          'shadow-lg',
        );
        t.classList.add('text-stone-500', 'border-transparent');
      });

      // Encendemos la pestaña clickeada
      const targetContent = document.getElementById(tabTargetId);
      const targetTab = document.querySelector(
        `.tab-btn[data-target="${tabTargetId}"]`,
      );

      if (targetContent && targetTab) {
        targetContent.classList.remove('hidden');
        targetContent.classList.add('block');

        targetTab.classList.remove('text-stone-500', 'border-transparent');
        targetTab.classList.add(
          'text-white',
          'border-amber-600',
          'dark:border-amber-500',
          'bg-stone-800',
          'dark:bg-[#0a0a0a]',
          'shadow-lg',
        );
      }
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        activateTab(tab.getAttribute('data-target'));
      });
    });

    // Exponemos la función al Window para poder resetear al navegar desde el Index
    window.resetResumenTabs = () => activateTab('temp1');
  });
</script>
