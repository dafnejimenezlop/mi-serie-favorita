---
// src/components/Header.astro
const navLinks = [
  { href: '#inicio', label: 'Inicio' },
  { href: '#sinopsis', label: 'Sinopsis' },
  { href: '#ciclos', label: 'Ciclos' },
  { href: '#personajes', label: 'Personajes' },
  { href: '#teorias', label: 'Teorías' },
];
---

<header
  class="fixed top-0 left-0 w-full z-50 bg-stone-50/90 dark:bg-black/80 backdrop-blur-sm border-b border-stone-200 dark:border-stone-800 transition-colors duration-300"
>
  <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="#inicio"
      class="text-2xl font-cinzel text-orange-900 dark:text-orange-500 font-bold tracking-widest hover:opacity-80 transition"
    >
      DARK
    </a>

    <ul class="hidden md:flex items-center space-x-6">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-semibold tracking-wide hover:text-orange-700 dark:hover:text-orange-400 transition"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center space-x-4">
      <button
        id="themeToggle"
        class="p-2 rounded-full border border-stone-300 dark:border-stone-700 hover:bg-stone-200 dark:hover:bg-stone-800 transition"
      >
        <svg
          id="sunIcon"
          class="w-5 h-5 hidden dark:block text-yellow-500"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M10 2a1 1 0 011 1v1a1 1 0 11-2 0V3a1 1 0 011-1zm4 8a4 4 0 11-8 0 4 4 0 018 0zm-.464 4.95l.707.707a1 1 0 001.414-1.414l-.707-.707a1 1 0 00-1.414 1.414zm2.12-10.607a1 1 0 010 1.414l-.706.707a1 1 0 11-1.414-1.414l.707-.707a1 1 0 011.414 0zM17 11a1 1 0 100-2h-1a1 1 0 100 2h1zm-7 4a1 1 0 011 1v1a1 1 0 11-2 0v-1a1 1 0 011-1zM5.05 17.95a1 1 0 01-1.414 0l-.707-.707a1 1 0 011.414-1.414l.707.707a1 1 0 010 1.414zm-.706-10.607a1 1 0 01-1.414 0l-.707-.707a1 1 0 011.414-1.414l.707.707a1 1 0 010 1.414zM4 11a1 1 0 100-2H3a1 1 0 100 2h1z"
          ></path>
        </svg>
        <svg
          id="moonIcon"
          class="w-5 h-5 block dark:hidden text-stone-700"
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path
            d="M17.293 13.293A8 8 0 016.707 2.707a8.001 8.001 0 1010.586 10.586z"
          ></path>
        </svg>
      </button>

      <button
        id="mobileMenuButton"
        class="md:hidden p-2 rounded hover:bg-stone-200 dark:hover:bg-stone-800"
      >
        <svg
          class="w-6 h-6 text-stone-900 dark:text-stone-100"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const handleToggleClick = () => {
      const element = document.documentElement;
      element.classList.toggle('dark');
      const isDark = element.classList.contains('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    };
    document
      .getElementById('themeToggle')
      .addEventListener('click', handleToggleClick);
  });
</script>
