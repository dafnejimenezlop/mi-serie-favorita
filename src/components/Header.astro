                        <a class="nav-link text-light fw-bold me-3 ms-3" href="/resumenTemporada"><i class="bi bi-mortarboard-fill text-warning"></i>&nbsp; Resumen</a>
                    </li>
                    <li class="navbar-item dropdown pe-1 me-1">
