<header>
    <div class="container-fluid">
        <div class="row foot2">
            <ul class="nav">
                <li class="nav-item me-auto ms-2 d-none d-xl-block"><a class="nav-link" href="#"><img src="/public/img/prueba.png" alt="Vega Media" style="width:125px" class="rounded-2"></a></li>
                <li class="nav-item me-auto ms-2 d-none d-lg-block d-xl-none"><a class="nav-link" href="#"><img src="/public/img/prueba.png" alt="Vega Media" style="width:80px" class="rounded-2"></a></li>
