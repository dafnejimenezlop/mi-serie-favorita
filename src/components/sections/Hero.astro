---
// src/components/sections/Hero.astro
---

<section
  id="inicio"
  class="relative h-screen bg-black transition-colors duration-300 overflow-hidden flex items-center justify-center"
>
  <div
    class="absolute top-1/2 left-1/2 w-[100vw] h-[56.25vw] min-h-[100vh] min-w-[177.77vh] -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-30 dark:opacity-20 z-0"
  >
    <div id="youtube-bg-player" class="w-full h-full"></div>
  </div>

  <div class="relative z-10 text-center space-y-6 px-6 pt-24">
    <h1
      class="text-6xl md:text-9xl font-cinzel text-amber-500 font-bold tracking-widest drop-shadow-2xl"
      data-aos="zoom-in"
      data-aos-duration="1500"
    >
      DARK
    </h1>
    <p
      class="text-lg md:text-3xl font-light text-stone-100 tracking-[0.15em] font-cinzel max-w-3xl mx-auto drop-shadow-lg"
      data-aos="fade-up"
      data-aos-delay="500"
    >
      LA CUESTIÓN NO ES CÓMO, SINO CUÁNDO.
    </p>
    <div
      data-aos="fade-up"
      data-aos-delay="1000"
      class="pt-8 pointer-events-auto"
    >
      <a
        href="#sinopsis"
        class="inline-block px-12 py-4 rounded border border-amber-500 text-amber-500 font-cinzel font-bold tracking-[0.2em] uppercase hover:bg-amber-500 hover:text-black hover:-translate-y-1 transition duration-500 backdrop-blur-sm bg-black/30"
      >
        Empezar Ciclo
      </a>
    </div>
  </div>

  <div
    class="absolute bottom-6 right-6 md:bottom-10 md:right-10 z-20 flex items-center space-x-3 md:space-x-4"
  >
    <button
      id="btnMute"
      aria-label="Mutear sonido"
      class="p-2.5 md:p-3 rounded-full bg-black/40 border border-amber-500/50 text-amber-500 hover:bg-amber-500 hover:text-black transition-all duration-300 backdrop-blur-md group"
    >
      <svg
        id="icon-muted"
        class="w-5 h-5 md:w-6 md:h-6 block group-hover:scale-110 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
          clip-rule="evenodd"></path><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg
      >
      <svg
        id="icon-unmuted"
        class="w-5 h-5 md:w-6 md:h-6 hidden group-hover:scale-110 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
        ></path></svg
      >
    </button>

    <button
      id="btnPlayPause"
      aria-label="Pausar vídeo"
      class="p-2.5 md:p-3 rounded-full bg-black/40 border border-amber-500/50 text-amber-500 hover:bg-amber-500 hover:text-black transition-all duration-300 backdrop-blur-md group"
    >
      <svg
        id="icon-pause"
        class="w-5 h-5 md:w-6 md:h-6 block group-hover:scale-110 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
      >
      <svg
        id="icon-play"
        class="w-5 h-5 md:w-6 md:h-6 hidden group-hover:scale-110 transition-transform"
        fill="currentColor"
        viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg
      >
    </button>

    <button
      id="btnModal"
      aria-label="Ver en pantalla completa"
      class="p-2.5 md:p-3 rounded-full bg-black/40 border border-amber-500/50 text-amber-500 hover:bg-amber-500 hover:text-black transition-all duration-300 backdrop-blur-md group"
    >
      <svg
        class="w-5 h-5 md:w-6 md:h-6 group-hover:scale-110 transition-transform"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"
        ></path></svg
      >
    </button>
  </div>
</section>

<script is:inline>
  // 1. Cargar la API de YouTube de forma asíncrona
  var tag = document.createElement('script');
  tag.src = 'https://www.youtube.com/iframe_api';
  var firstScriptTag = document.getElementsByTagName('script')[0];
  firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

  var bgPlayer;
  var modalPlayer;
  var isPlaying = true;
  var isMuted = true;

  // 2. Función que ejecuta YouTube cuando la API está lista
  function onYouTubeIframeAPIReady() {
    // --- Reproductor de Fondo ---
    bgPlayer = new YT.Player('youtube-bg-player', {
      videoId: '14FGjkrrXFk', // ID de tu vídeo
      playerVars: {
        autoplay: 1,
        controls: 0, // Sin controles
        showinfo: 0,
        rel: 0,
        loop: 1,
        playlist: '14FGjkrrXFk', // Necesario para loop
        mute: 1, // Obligatorio mutear para que funcione autoplay
        playsinline: 1,
        modestbranding: 1,
        disablekb: 1,
      },
      events: {
        onReady: onPlayerReady,
      },
    });

    // --- Reproductor del Modal ---
    modalPlayer = new YT.Player('youtube-modal-player', {
      videoId: '14FGjkrrXFk',
      playerVars: {
        autoplay: 0,
        controls: 1, // Con controles normales
        rel: 0,
      },
    });
  }

  // 3. Cuando el vídeo de fondo esté listo para controlarse
  function onPlayerReady(event) {
    event.target.playVideo();

    // --- LÓGICA BOTÓN PLAY / PAUSE ---
    const btnPlayPause = document.getElementById('btnPlayPause');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');

    btnPlayPause.addEventListener('click', () => {
      if (isPlaying) {
        bgPlayer.pauseVideo();
        iconPause.classList.add('hidden');
        iconPause.classList.remove('block');
        iconPlay.classList.add('block');
        iconPlay.classList.remove('hidden');
      } else {
        bgPlayer.playVideo();
        iconPlay.classList.add('hidden');
        iconPlay.classList.remove('block');
        iconPause.classList.add('block');
        iconPause.classList.remove('hidden');
      }
      isPlaying = !isPlaying;
    });

    // --- LÓGICA BOTÓN MUTE ---
    const btnMute = document.getElementById('btnMute');
    const iconMuted = document.getElementById('icon-muted');
    const iconUnmuted = document.getElementById('icon-unmuted');

    btnMute.addEventListener('click', () => {
      if (isMuted) {
        bgPlayer.unMute();
        iconMuted.classList.add('hidden');
        iconMuted.classList.remove('block');
        iconUnmuted.classList.add('block');
        iconUnmuted.classList.remove('hidden');
      } else {
        bgPlayer.mute();
        iconUnmuted.classList.add('hidden');
        iconUnmuted.classList.remove('block');
        iconMuted.classList.add('block');
        iconMuted.classList.remove('hidden');
      }
      isMuted = !isMuted;
    });
  }

  // --- LÓGICA DEL MODAL ---
  document.addEventListener('DOMContentLoaded', () => {
    const btnModal = document.getElementById('btnModal');
    const btnCloseModal = document.getElementById('btnCloseModal');
    const videoModal = document.getElementById('videoModal');

    // Abrir Modal
    btnModal.addEventListener('click', () => {
      videoModal.classList.remove('hidden');
      videoModal.classList.add('flex');
      setTimeout(() => videoModal.classList.remove('opacity-0'), 10);

      // Pausar el fondo
      if (bgPlayer && typeof bgPlayer.pauseVideo === 'function') {
        bgPlayer.pauseVideo();
      }
      // Reproducir el modal
      if (modalPlayer && typeof modalPlayer.playVideo === 'function') {
        modalPlayer.playVideo();
      }
    });

    // Cerrar Modal
    btnCloseModal.addEventListener('click', () => {
      videoModal.classList.add('opacity-0');
      setTimeout(() => {
        videoModal.classList.add('hidden');
        videoModal.classList.remove('flex');
      }, 500);

      // Pausar modal
      if (modalPlayer && typeof modalPlayer.pauseVideo === 'function') {
        modalPlayer.pauseVideo();
      }
      // Reanudar fondo (solo si estaba reproduciendo antes de abrir el modal)
      if (isPlaying && bgPlayer && typeof bgPlayer.playVideo === 'function') {
        bgPlayer.playVideo();
      }
    });
  });
</script>
