---
// src/components/sections/Timeline.astro

// Ampliamos los datos para tener una descripción corta (por defecto) y una larga (al pasar el ratón)
const ciclos = [
  {
    year: '1953',
    title: 'El Origen',
    shortDesc: 'Se construye la planta nuclear.',
    longDesc:
      'En la época de la posguerra, los cimientos de la tragedia se establecen con la construcción de la central de Winden. Las acciones del pasado comienzan a reescribir el futuro.',
    delay: '100',
  },
  {
    year: '1986',
    title: 'El Nudo',
    shortDesc: 'El agujero de gusano se estabiliza.',
    longDesc:
      'Un misterioso incidente en la central nuclear crea el pasaje en las cuevas. Es la época central donde convergen todos los viajeros y los secretos más oscuros.',
    delay: '300',
  },
  {
    year: '2019',
    title: 'El Final',
    shortDesc: 'Mikkel Nielsen desaparece.',
    longDesc:
      'La aparente calma de Winden se rompe. La desaparición de un niño es el catalizador que detona el apocalipsis y cierra el círculo interminable de las tres épocas.',
    delay: '500',
  },
];
---

<section
  id="ciclos"
  class="py-24 bg-transparent transition-colors duration-300 overflow-hidden relative"
>
  <div class="container mx-auto px-6 text-center space-y-16 md:space-y-24">
    <h2
      class="text-4xl md:text-5xl font-cinzel text-amber-500 font-bold tracking-[0.1em] transition-colors uppercase text-center drop-shadow-lg"
      data-aos="zoom-in"
      data-aos-duration="1000"
    >
      Los Tres Ciclos del Tiempo
    </h2>

    <div class="relative max-w-6xl mx-auto">
      <div
        class="hidden md:block absolute top-[40%] left-10 right-10 h-[1px] bg-gradient-to-r from-transparent via-amber-500/50 to-transparent z-0"
      >
      </div>

      <div
        class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 relative z-10"
      >
        {
          ciclos.map((ciclo) => (
            /* Tarjeta con efecto Group para interactividad Hover */
            <div
              class="relative group bg-stone-950/60 dark:bg-black/60 backdrop-blur-md p-8 md:p-10 rounded-xl border border-stone-800 hover:border-amber-500/60 shadow-xl hover:shadow-[0_0_30px_rgba(245,158,11,0.15)] transition-all duration-500 overflow-hidden min-h-[320px] flex flex-col items-center cursor-pointer"
              data-aos="fade-up"
              data-aos-delay={ciclo.delay}
            >
              <div class="absolute inset-0 bg-gradient-to-b from-amber-500/0 to-amber-500/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0" />

              <div class="relative z-10 w-full flex flex-col items-center transition-transform duration-500 transform group-hover:-translate-y-6 mt-10 group-hover:mt-4">
                <div class="w-3 h-3 rounded-full bg-stone-600 group-hover:bg-amber-500 transition-colors duration-500 mb-6 shadow-lg group-hover:shadow-[0_0_15px_rgba(245,158,11,0.8)]" />

                <h3 class="text-5xl md:text-6xl font-cinzel font-bold text-stone-300 group-hover:text-amber-500 transition-colors duration-500">
                  {ciclo.year}
                </h3>

                <p class="text-amber-600/80 group-hover:text-amber-400 mt-4 tracking-[0.2em] uppercase text-sm font-bold transition-colors duration-500">
                  {ciclo.title}
                </p>
                <p class="text-xs text-stone-500 mt-2 font-mono uppercase tracking-wider group-hover:opacity-0 transition-opacity duration-300">
                  {ciclo.shortDesc}
                </p>
              </div>

              <div class="absolute bottom-6 left-0 w-full px-8 text-center opacity-0 translate-y-8 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 ease-out delay-75 z-10">
                <div class="h-px w-12 bg-amber-500/30 mx-auto mb-4" />
                <p class="text-sm text-stone-300 font-light leading-relaxed">
                  {ciclo.longDesc}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div data-aos="fade-in" data-aos-delay="600">
      <p
        class="text-stone-500 font-cinzel italic tracking-widest text-sm md:text-base"
      >
        "El principio es el fin, y el fin es el principio."
      </p>
    </div>
  </div>
</section>
