---
// src/components/sections/Testimonials.astro

const reviews = [
  {
    author: 'H.G. Tannhaus',
    role: 'Creador del aparato',
    date: '21 de Junio, 1986',
    comment: 'Esencial. El apocalipsis ha llegado, y es hermoso.',
    rating: 3,
    image: '/avatar.png',
    colorClass: 'border-emerald-500/50 shadow-emerald-900/20',
    textClass: 'text-emerald-500',
  },
  {
    author: 'Noah',
    role: 'Sacerdote del tiempo',
    date: '12 de Noviembre, 1953',
    comment:
      'La mejor serie que he visto en mi corta vida. Sic Mundus Creatus Est.',
    rating: 5,
    image: '/avatar2.png',
    colorClass: 'border-amber-500/50 shadow-amber-900/20',
    textClass: 'text-amber-500',
  },
  {
    author: 'Martha Nielsen',
    role: 'Viajera',
    date: '4 de Noviembre, 2019',
    comment:
      'Todo está conectado. Un viaje cinemático que me dejó sin aliento. Jamás volverás a ver el tiempo de la misma manera. Necesito verla otra vez para entenderla',
    rating: 1,
    image: '/avatar3.png',
    colorClass: 'border-blue-500/50 shadow-blue-900/20',
    textClass: 'text-blue-500',
  },
  {
    author: 'Jonas Kahnwald',
    role: 'El Desconocido',
    date: '27 de Junio, 2052',
    comment: 'El final es el principio. Una obra maestra del suspense alemán.',
    rating: 5,
    image: '/avatar4.png',
    colorClass: 'border-rose-500/50 shadow-rose-900/20',
    textClass: 'text-rose-500',
  },
  {
    author: 'Anonimo',
    role: 'Espectador',
    date: 'Estreno 2017',
    comment:
      'Recomiendo esta serie a todo el mundo. Es un viaje emocional y mental que no olvidarás. No os arrepentiréis de verla.',
    rating: 5,
    image: '/avatar5.png',
    colorClass: 'border-lime-500/50 shadow-lime-900/20',
    textClass: 'text-lime-500',
  },
  {
    author: 'Periodista',
    role: 'Crítico de Cine',
    date: 'Reseña Destacada',
    comment:
      '¿Alguna vez os habéis preguntado por qué la serie de Dark es tan popular? Es simple: es una obra maestra del cine y la televisión.',
    rating: 5,
    image: '/avatar6.png',
    colorClass: 'border-cyan-500/50 shadow-cyan-900/20',
    textClass: 'text-cyan-500',
  },
];
---

<style>
  .testimonials-slider .swiper-slide {
    height: auto;
    display: flex;
  }
</style>

<section
  id="testimonios"
  class="py-24 bg-transparent transition-colors duration-300 overflow-hidden relative"
>
  <div class="container mx-auto px-6">
    <h2
      class="text-3xl md:text-5xl font-cinzel text-amber-500 font-bold transition-colors text-center mb-16"
      data-aos="zoom-in"
    >
      Ecos del Futuro
    </h2>

    <div class="relative px-8 md:px-16 max-w-7xl mx-auto">
      <div
        class="swiper-container testimonials-slider overflow-hidden"
        data-aos="fade-up"
      >
        <div class="swiper-wrapper py-12">
          {
            reviews.map((review) => (
              <div class="swiper-slide w-full">
                <div
                  class={`bg-stone-50/90 dark:bg-stone-900/80 p-6 md:p-10 rounded-lg border ${review.colorClass} shadow-xl space-y-6 w-full h-full flex flex-col justify-between relative z-10 transition-transform duration-300 hover:-translate-y-2 backdrop-blur-md`}
                >
                  <div
                    class={`absolute -top-10 left-1/2 transform -translate-x-1/2 w-20 h-20 md:w-24 md:h-24 rounded-full border-4 bg-black overflow-hidden shadow-2xl z-20 ${review.colorClass}`}
                  >
                    <img
                      src={review.image}
                      alt={review.author}
                      class="w-full h-full object-cover"
                    />
                  </div>

                  <div class="flex-grow pt-8 md:pt-10 flex flex-col justify-center">
                    <p class="text-base md:text-lg text-stone-900 dark:text-stone-100 font-cinzel text-center italic tracking-wide leading-relaxed">
                      "{review.comment}"
                    </p>
                  </div>

                  <div
                    class={`pt-5 border-t ${review.colorClass} mt-auto space-y-3`}
                  >
                    <div class="flex justify-center space-x-1 text-amber-500">
                      {Array.from({ length: 5 }).map((_, i) => (
                        <svg
                          class={`w-4 h-4 ${i < review.rating ? 'opacity-100' : 'opacity-20 grayscale'}`}
                          fill="currentColor"
                          viewBox="0 0 20 20"
                        >
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>

                    <div class="text-center space-y-1">
                      <p
                        class={`text-sm md:text-base font-bold font-cinzel uppercase tracking-widest ${review.textClass}`}
                      >
                        {review.author}
                      </p>
                      <p class="text-[11px] md:text-xs text-stone-500 dark:text-stone-400 font-mono tracking-wider uppercase">
                        {review.role}
                      </p>
                      <p class="text-[10px] md:text-xs text-stone-400/80 dark:text-stone-500/80 italic pt-1">
                        {review.date}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="swiper-button-prev testimonials-prev !text-amber-500 !left-0 md:!-left-4"
      >
      </div>
      <div
        class="swiper-button-next testimonials-next !text-amber-500 !right-0 md:!-right-4"
      >
      </div>
    </div>
  </div>
</section>

<script is:inline src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.testimonials-slider', {
      loop: true,
      slidesPerView: 1,
      spaceBetween: 20,
      grabCursor: true,
      navigation: {
        nextEl: '.testimonials-next',
        prevEl: '.testimonials-prev',
      },
      breakpoints: {
        768: {
          slidesPerView: 2,
          spaceBetween: 30,
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 40,
        },
      },
    });
  });
</script>
