---
// src/components/sections/Testimonials.astro

// Array actualizado: Imágenes individuales y colores dinámicos por cada tarjeta.
const reviews = [
  {
    author: 'H.G. Tannhaus, Creador',
    comment: 'Esencial. El apocalipsis ha llegado, y es hermoso.',
    rating: 5,
    image: '/avatar.png', // Asegúrate de tener estas imágenes en public/
    colorClass: 'border-emerald-500/50 shadow-emerald-900/20',
    textClass: 'text-emerald-500',
  },
  {
    author: 'Noah, Un Visitante',
    comment:
      'La mejor serie que he visto en mi corta vida. Sic Mundus Creatus Est.',
    rating: 5,
    image: '/avatar2.png',
    colorClass: 'border-amber-500/50 shadow-amber-900/20',
    textClass: 'text-amber-500',
  },
  {
    author: 'Martha Nielsen',
    comment:
      'Todo está conectado. Un viaje cinemático que me dejó sin aliento. Jamás volverás a ver el tiempo de la misma manera.',
    rating: 4,
    image: '/avatar3.png',
    colorClass: 'border-blue-500/50 shadow-blue-900/20',
    textClass: 'text-blue-500',
  },
  {
    author: 'Jonas Kahnwald',
    comment: 'El final es el principio. Una obra maestra del suspense alemán.',
    rating: 5,
    image: '/avatar4.png', // Cambia por tu ruta real
    colorClass: 'border-rose-500/50 shadow-rose-900/20',
    textClass: 'text-rose-500',
  },
  {
    author: 'Anonimo',
    comment:
      'Recomiendo ver la serie al menos 3 veces para entenderla completamente. Cada detalle tiene un propósito, y el diseño de producción es simplemente espectacular.',
    rating: 6,
    image: '/avatar5.png', // Cambia por tu ruta real
    colorClass: 'border-red-500/50 shadow-red-900/20',
    textClass: 'text-red-500',
  },
];
---

<style>
  /* Forzamos a que todas las tarjetas (slides) compartan la misma altura y usen flexbox */
  .testimonials-slider .swiper-slide {
    height: auto;
    display: flex;
  }
</style>

<section
  id="testimonios"
  class="py-24 bg-black transition-colors duration-300 overflow-hidden relative"
>
  <div class="container mx-auto px-6">
    <h2
      class="text-3xl md:text-5xl font-cinzel text-amber-500 font-bold transition-colors text-center mb-16"
      data-aos="zoom-in"
    >
      Ecos del Futuro
    </h2>

    <div class="relative px-8 md:px-16 max-w-7xl mx-auto">
      <div
        class="swiper-container testimonials-slider overflow-hidden"
        data-aos="fade-up"
      >
        <div class="swiper-wrapper py-12">
          {
            reviews.map((review) => (
              <div class="swiper-slide w-full">
                <div
                  class={`bg-stone-50 dark:bg-stone-900 p-6 md:p-10 rounded-lg border ${review.colorClass} shadow-xl space-y-6 w-full h-full flex flex-col justify-between relative z-10 transition-transform duration-300 hover:-translate-y-2`}
                >
                  <div
                    class={`absolute -top-10 left-1/2 transform -translate-x-1/2 w-20 h-20 md:w-24 md:h-24 rounded-full border-4 bg-black overflow-hidden shadow-2xl z-20 ${review.colorClass}`}
                  >
                    <img
                      src={review.image}
                      alt={review.author}
                      class="w-full h-full object-cover"
                    />
                  </div>

                  <div class="flex-grow pt-8 md:pt-10">
                    <p class="text-base md:text-lg text-stone-900 dark:text-stone-100 font-cinzel text-center italic tracking-wide leading-relaxed">
                      "{review.comment}"
                    </p>
                  </div>

                  <div class={`pt-4 border-t ${review.colorClass} mt-auto`}>
                    <p
                      class={`text-xs md:text-sm font-bold font-cinzel uppercase tracking-widest text-center ${review.textClass}`}
                    >
                      {review.author}
                    </p>
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>

      <div
        class="swiper-button-prev testimonials-prev !text-amber-500 !left-0 md:!-left-4"
      >
      </div>
      <div
        class="swiper-button-next testimonials-next !text-amber-500 !right-0 md:!-right-4"
      >
      </div>
    </div>
  </div>
</section>

<script is:inline src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>
<link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    new Swiper('.testimonials-slider', {
      loop: true,
      slidesPerView: 1, // 1 tarjeta en móvil
      spaceBetween: 20,
      grabCursor: true,
      navigation: {
        nextEl: '.testimonials-next',
        prevEl: '.testimonials-prev',
      },
      breakpoints: {
        768: {
          slidesPerView: 2, // 2 tarjetas en tablet
          spaceBetween: 30,
        },
        1024: {
          slidesPerView: 3, // 3 tarjetas en escritorio
          spaceBetween: 40,
        },
      },
    });
  });
</script>
