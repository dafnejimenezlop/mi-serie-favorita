<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabsAclara = document.querySelectorAll('.tab-btn-aclara');
    const contentsAclara = document.querySelectorAll('.tab-content-aclara');

    function activateAclaraTab(tabTargetId) {
      contentsAclara.forEach((c) => {
        c.classList.remove('block');
        c.classList.add('hidden');
      });

      tabsAclara.forEach((t) => {
        t.classList.remove(
          'text-stone-900',
          'dark:text-white',
          'border-amber-600',
          'dark:border-amber-500',
          'bg-stone-300/80',
          'dark:bg-stone-800/80',
          'shadow-[0_-4px_20px_rgba(0,0,0,0.05)]',
          'dark:shadow-[0_-4px_20px_rgba(0,0,0,0.3)]',
        );
        t.classList.add(
          'text-stone-500',
          'dark:text-stone-500',
          'border-transparent',
        );
      });

      const targetContent = document.getElementById(tabTargetId);
      const targetTab = document.querySelector(
        `.tab-btn-aclara[data-target="${tabTargetId}"]`,
      );

      if (targetContent && targetTab) {
        targetContent.classList.remove('hidden');
        targetContent.classList.add('block');

        targetTab.classList.remove(
          'text-stone-500',
          'dark:text-stone-500',
          'border-transparent',
        );
        targetTab.classList.add(
          'text-stone-900',
          'dark:text-white',
          'border-amber-600',
          'dark:border-amber-500',
          'bg-stone-300/80',
          'dark:bg-stone-800/80',
          'shadow-[0_-4px_20px_rgba(0,0,0,0.05)]',
          'dark:shadow-[0_-4px_20px_rgba(0,0,0,0.3)]',
        );
      }
    }

    tabsAclara.forEach((tab) => {
      tab.addEventListener('click', () => {
        activateAclaraTab(tab.getAttribute('data-target'));
      });
    });

    // Exponemos para resetear cuando se cambie la vista desde index.astro
    window.resetAclaracionesTabs = () =>
      activateAclaraTab('aclara-explicacion');
  });
</script>
