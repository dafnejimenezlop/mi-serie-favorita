---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Ratings from '../components/sections/Ratings.astro';
import Timeline from '../components/sections/Timeline.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import Whatsapp from '../components/Whatsapp.astro';
import Resumen from '../components/Resumen.astro';
import Aclaraciones from '../components/Aclaraciones.astro';
---

<BaseLayout title="DARK - Sic Mundus">
  <div id="vista-inicio" class="block transition-opacity duration-500">
    <Hero />
    <Ratings />
    <Timeline />
    <Testimonials />
  </div>

  <div id="vista-resumen" class="hidden transition-opacity duration-500">
    <Resumen />
  </div>

  <div id="vista-aclaraciones" class="hidden transition-opacity duration-500">
    <Aclaraciones />
  </div>

  <Whatsapp />
</BaseLayout>

<script is:inline>
  function controlarVistas() {
    const hash = window.location.hash || '#inicio';
    const vistas = ['vista-inicio', 'vista-resumen', 'vista-aclaraciones'];

    // Decidir cuál es la vista activa
    let vistaActiva = 'vista-inicio';
    if (hash === '#resumen') vistaActiva = 'vista-resumen';
    if (hash === '#aclaraciones') vistaActiva = 'vista-aclaraciones';

    // Mostrar solo la vista activa y ocultar el resto
    vistas.forEach((v) => {
      const el = document.getElementById(v);
      if (el) {
        if (v === vistaActiva) {
          el.classList.remove('hidden');
          el.classList.add('block');
        } else {
          el.classList.add('hidden');
          el.classList.remove('block');
        }
      }
    });

    window.scrollTo({ top: 0, behavior: 'smooth' });

    // Forzar a AOS a que actualice las animaciones al cambiar
    setTimeout(() => {
      if (typeof AOS !== 'undefined') AOS.refresh();
    }, 50);

    // Resetear las pestañas a la primera cuando entras en cada sección
    if (
      vistaActiva === 'vista-resumen' &&
      typeof window.resetResumenTabs === 'function'
    ) {
      window.resetResumenTabs();
    }
    if (
      vistaActiva === 'vista-aclaraciones' &&
      typeof window.resetAclaracionesTabs === 'function'
    ) {
      window.resetAclaracionesTabs();
    }
  }

  document.addEventListener('DOMContentLoaded', controlarVistas);
  window.addEventListener('hashchange', controlarVistas);
</script>
