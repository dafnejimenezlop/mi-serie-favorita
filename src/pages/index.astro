---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="DARK">
  <section
    id="inicio"
    class="relative h-screen flex items-center justify-center bg-black transition-colors duration-300"
  >
    <img
      src="https://images.unsplash.com/photo-1579970401774-4b51c140c83a?q=80&w=2000&auto=format&fit=crop"
      alt="Reloj antiguo y túnel oscuro"
      class="absolute inset-0 w-full h-full object-cover opacity-50 transition-opacity"
    />

    <div class="relative z-10 text-center space-y-4 px-6">
      <h1
        class="text-5xl md:text-8xl font-cinzel text-orange-500 font-bold tracking-widest"
        data-aos="zoom-in"
        data-aos-duration="1200"
      >
        DARK
      </h1>
      <p
        class="text-lg md:text-2xl font-light text-stone-200 tracking-wide font-sans max-w-2xl mx-auto"
        data-aos="fade-up"
        data-aos-delay="400"
      >
        La cuestión no es cómo, si no cuándo.
      </p>
      <div data-aos="fade-up" data-aos-delay="800">
        <a
          href="#sinopsis"
          class="inline-block px-8 py-3 rounded-full border border-orange-500 text-orange-500 font-semibold hover:bg-orange-500 hover:text-black transition"
        >
          Empezar Ciclo
        </a>
      </div>
    </div>
  </section>

  <section id="sinopsis" class="py-24 transition-colors duration-300">
    <div class="container mx-auto px-6 grid md:grid-cols-2 gap-12 items-center">
      <div data-aos="fade-right">
        <img
          src="https://via.placeholder.com/600x400/1C1917/A87D4F"
          alt="Imagen Sinopsis Winden"
          class="rounded-lg shadow-xl shadow-stone-300 dark:shadow-stone-950 transition-shadow"
        />
      </div>

      <div class="space-y-6" data-aos="fade-left" data-aos-delay="300">
        <h2
          class="text-4xl font-cinzel text-orange-900 dark:text-orange-400 font-bold transition-colors"
        >
          La Desaparición
        </h2>
        <p class="text-lg text-stone-800 dark:text-stone-200 transition-colors">
          Winden, 2019. Un pequeño pueblo alemán donde nunca pasa nada. O eso
          parecía. La desaparición misteriosa de un niño abre un agujero negro
          que conecta pasado, presente y futuro de cuatro familias.
        </p>
        <p class="text-md text-stone-700 dark:text-stone-300 transition-colors">
          El nudo que lo une todo está a punto de apretarse. "Sic Mundus Creatus
          Est".
        </p>
      </div>
    </div>
  </section>

  <section
    id="ciclos"
    class="py-24 bg-stone-100 dark:bg-black/50 transition-colors duration-300"
  >
    <div class="container mx-auto px-6 text-center space-y-12">
      <h2
        class="text-4xl font-cinzel text-orange-900 dark:text-orange-400 font-bold transition-colors"
        data-aos="zoom-in"
      >
        Los Tres Ciclos
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div
          class="bg-stone-50 dark:bg-black p-8 rounded-lg border border-stone-200 dark:border-stone-800 transition-colors"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <h3
            class="text-2xl font-cinzel font-bold text-orange-800 dark:text-orange-300"
          >
            1953
          </h3>
          <p class="text-stone-700 dark:text-stone-300">Donde todo empezó.</p>
        </div>
        <div
          class="bg-stone-50 dark:bg-black p-8 rounded-lg border border-stone-200 dark:border-stone-800 transition-colors"
          data-aos="fade-up"
          data-aos-delay="200"
        >
          <h3
            class="text-2xl font-cinzel font-bold text-orange-800 dark:text-orange-300"
          >
            1986
          </h3>
          <p class="text-stone-700 dark:text-stone-300">
            Donde el nudo se apretó.
          </p>
        </div>
        <div
          class="bg-stone-50 dark:bg-black p-8 rounded-lg border border-stone-200 dark:border-stone-800 transition-colors"
          data-aos="fade-up"
          data-aos-delay="300"
        >
          <h3
            class="text-2xl font-cinzel font-bold text-orange-800 dark:text-orange-300"
          >
            2019
          </h3>
          <p class="text-stone-700 dark:text-stone-300">
            Donde el nudo debe romperse.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
