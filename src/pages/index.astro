---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="DARK">
  <section
    id="inicio"
    class="relative h-screen flex items-center justify-center bg-black transition-colors duration-300 overflow-hidden"
  >
    <div
      class="absolute top-1/2 left-1/2 w-[100vw] h-[56.25vw] min-h-[100vh] min-w-[177.77vh] -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-30 dark:opacity-20 z-0"
    >
      <div id="youtube-bg-player" class="w-full h-full"></div>
    </div>

    <div class="relative z-10 text-center space-y-6 px-6 pt-24">
      <h1
        class="text-6xl md:text-9xl font-cinzel text-amber-500 font-bold tracking-widest drop-shadow-2xl"
        data-aos="zoom-in"
        data-aos-duration="1500"
      >
        DARK
      </h1>
      <p
        class="text-lg md:text-3xl font-light text-stone-100 tracking-[0.15em] font-cinzel max-w-3xl mx-auto drop-shadow-lg"
        data-aos="fade-up"
        data-aos-delay="500"
      >
        LA CUESTIÓN NO ES CÓMO, SINO CUÁNDO.
      </p>
      <div
        data-aos="fade-up"
        data-aos-delay="1000"
        class="pt-8 pointer-events-auto"
      >
        <a
          href="#sinopsis"
          class="inline-block px-8 md:px-12 py-3 md:py-4 rounded border border-amber-500 text-amber-500 font-cinzel font-bold tracking-[0.1em] md:tracking-[0.2em] uppercase hover:bg-amber-500 hover:text-black hover:-translate-y-1 transition duration-500 backdrop-blur-sm bg-black/30"
        >
          Empezar Ciclo
        </a>
      </div>
    </div>

    <div
      class="absolute bottom-6 right-6 md:bottom-10 md:right-10 z-20 flex items-center space-x-3 md:space-x-4"
    >
      <button
        id="btnMute"
        aria-label="Mutear sonido"
        class="p-2.5 md:p-3 rounded-full bg-black/40 border border-amber-500/50 text-amber-500 hover:bg-amber-500 hover:text-black transition-all duration-300 backdrop-blur-md group"
      >
        <svg
          id="icon-muted"
          class="w-5 h-5 md:w-6 md:h-6 block group-hover:scale-110 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
            clip-rule="evenodd"></path><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2"></path></svg
        >
        <svg
          id="icon-unmuted"
          class="w-5 h-5 md:w-6 md:h-6 hidden group-hover:scale-110 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15.536 8.464a5 5 0 010 7.072m2.828-9.9a9 9 0 010 12.728M5.586 15H4a1 1 0 01-1-1v-4a1 1 0 011-1h1.586l4.707-4.707C10.923 3.663 12 4.109 12 5v14c0 .891-1.077 1.337-1.707.707L5.586 15z"
          ></path></svg
        >
      </button>

      <button
        id="btnPlayPause"
        aria-label="Pausar vídeo"
        class="p-2.5 md:p-3 rounded-full bg-black/40 border border-amber-500/50 text-amber-500 hover:bg-amber-500 hover:text-black transition-all duration-300 backdrop-blur-md group"
      >
        <svg
          id="icon-pause"
          class="w-5 h-5 md:w-6 md:h-6 block group-hover:scale-110 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M10 9v6m4-6v6m7-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
        >
        <svg
          id="icon-play"
          class="w-5 h-5 md:w-6 md:h-6 hidden group-hover:scale-110 transition-transform"
          fill="currentColor"
          viewBox="0 0 24 24"><path d="M8 5v14l11-7z"></path></svg
        >
      </button>

      <button
        id="btnModal"
        aria-label="Ver en pantalla completa"
        class="p-2.5 md:p-3 rounded-full bg-black/40 border border-amber-500/50 text-amber-500 hover:bg-amber-500 hover:text-black transition-all duration-300 backdrop-blur-md group"
      >
        <svg
          class="w-5 h-5 md:w-6 md:h-6 group-hover:scale-110 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"
          ></path></svg
        >
      </button>
    </div>
  </section>

  <div
    id="videoModal"
    class="fixed inset-0 z-[100] hidden flex-col items-center justify-center bg-black/95 backdrop-blur-lg opacity-0 transition-opacity duration-500 p-4"
  >
    <button
      id="btnCloseModal"
      class="absolute top-4 right-4 md:top-8 md:right-8 z-[110] p-2 bg-stone-900/80 hover:bg-black text-stone-400 hover:text-amber-500 rounded-full transition-all border border-stone-700 hover:border-amber-500"
    >
      <svg
        class="w-8 h-8 md:w-10 md:h-10"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M6 18L18 6M6 6l12 12"></path></svg
      >
    </button>

    <div
      class="relative w-full max-w-6xl aspect-video bg-black rounded-lg shadow-2xl overflow-hidden border border-stone-800"
    >
      <div id="youtube-modal-player" class="w-full h-full"></div>
    </div>
  </div>

  <section
    id="sinopsis"
    class="py-32 bg-stone-50 dark:bg-black transition-colors duration-300"
  >
    <div class="container mx-auto px-6 grid md:grid-cols-2 gap-16 items-center">
      <div data-aos="fade-right" data-aos-duration="1000">
        <img
          src="/familia.jpg"
          alt="Winden"
          class="rounded border border-stone-200 dark:border-stone-900 shadow-2xl dark:shadow-amber-900/10 transition duration-300 filter grayscale hover:grayscale-0"
        />
      </div>

      <div
        class="space-y-8"
        data-aos="fade-left"
        data-aos-duration="1000"
        data-aos-delay="200"
      >
        <h2
          class="text-4xl md:text-5xl font-cinzel text-amber-950 dark:text-amber-500 font-bold tracking-[0.1em] transition-colors uppercase"
        >
          Winden
        </h2>
        <p
          class="text-lg text-stone-800 dark:text-stone-300 font-light leading-relaxed transition-colors tracking-wide"
        >
          Winden, 2019. Un pequeño pueblo alemán donde la aparente calma se
          rompe con la desaparición misteriosa de un niño. No es un crimen
          ordinario; es el catalizador de un rompecabezas narrativo complejo.
        </p>
        <p
          class="text-md text-stone-600 dark:text-stone-400 font-light italic transition-colors tracking-wide"
        >
          La búsqueda de Mikkel Nielsen une las vidas y secretos de cuatro
          familias: los Kahnwald, los Nielsen, los Doppler y los Tiedemann.
        </p>
        <div class="pt-2 h-px w-24 bg-amber-500 transition-colors"></div>
      </div>
    </div>
  </section>

  <section
    id="ciclos"
    class="py-32 bg-stone-200 dark:bg-stone-900 transition-colors duration-300"
  >
    <div class="container mx-auto px-6 text-center space-y-20">
      <h2
        class="text-4xl md:text-5xl font-cinzel text-amber-950 dark:text-amber-500 font-bold tracking-[0.1em] transition-colors uppercase"
        data-aos="zoom-in"
        data-aos-duration="1000"
      >
        Los Tres Ciclos
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        <div
          class="bg-stone-50 dark:bg-black p-12 rounded border border-stone-300 dark:border-stone-800 shadow-xl transition-colors hover:border-amber-500 dark:hover:border-amber-500 duration-500 group"
          data-aos="fade-up"
          data-aos-delay="100"
        >
          <h3
            class="text-4xl font-cinzel font-bold text-amber-900 dark:text-amber-500 group-hover:scale-110 transition-transform duration-500"
          >
            1953
          </h3>
          <p
            class="text-stone-600 dark:text-stone-400 mt-6 tracking-widest uppercase text-sm font-semibold"
          >
            El Origen
          </p>
        </div>
        <div
          class="bg-stone-50 dark:bg-black p-12 rounded border border-stone-300 dark:border-stone-800 shadow-xl transition-colors hover:border-amber-500 dark:hover:border-amber-500 duration-500 group"
          data-aos="fade-up"
          data-aos-delay="300"
        >
          <h3
            class="text-4xl font-cinzel font-bold text-amber-900 dark:text-amber-500 group-hover:scale-110 transition-transform duration-500"
          >
            1986
          </h3>
          <p
            class="text-stone-600 dark:text-stone-400 mt-6 tracking-widest uppercase text-sm font-semibold"
          >
            El Nudo
          </p>
        </div>
        <div
          class="bg-stone-50 dark:bg-black p-12 rounded border border-stone-300 dark:border-stone-800 shadow-xl transition-colors hover:border-amber-500 dark:hover:border-amber-500 duration-500 group"
          data-aos="fade-up"
          data-aos-delay="500"
        >
          <h3
            class="text-4xl font-cinzel font-bold text-amber-900 dark:text-amber-500 group-hover:scale-110 transition-transform duration-500"
          >
            2019
          </h3>
          <p
            class="text-stone-600 dark:text-stone-400 mt-6 tracking-widest uppercase text-sm font-semibold"
          >
            El Final
          </p>
        </div>
      </div>
    </div>
  </section>

  <section id="teorias" class="py-24 bg-black transition-colors duration-300">
    <div class="container mx-auto px-6 text-center space-y-16">
      <h2
        class="text-4xl md:text-5xl font-cinzel text-amber-500 font-bold transition-colors"
        data-aos="zoom-in"
      >
        Críticas de Críticos Notables
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <div class="space-y-4" data-aos="fade-right" data-aos-delay="200">
          <p class="text-5xl text-amber-500/30 font-cinzel font-bold">"</p>
          <p
            class="text-2xl text-stone-100 font-cinzel max-w-md mx-auto italic tracking-wide"
          >
            Esencial. El apocalipsis ha llegado, y es hermoso.
          </p>
          <p class="text-5xl text-amber-500/30 font-cinzel font-bold">"</p>
          <p class="text-sm font-semibold text-amber-400 pt-2">
            - H.G. Tannhaus, Creador
          </p>
        </div>

        <div class="space-y-4" data-aos="fade-left" data-aos-delay="400">
          <p class="text-5xl text-amber-500/30 font-cinzel font-bold">"</p>
          <p
            class="text-2xl text-stone-100 font-cinzel max-w-md mx-auto italic tracking-wide"
          >
            La mejor serie que he visto en mi corta vida. Sic Mundus Creatus
            Est.
          </p>
          <p class="text-5xl text-amber-500/30 font-cinzel font-bold">"</p>
          <p class="text-sm font-semibold text-amber-400 pt-2">
            - Noah, Un Visitante
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  var tag = document.createElement('script');
  tag.src = 'https://www.youtube.com/iframe_api';
  var firstScriptTag = document.getElementsByTagName('script')[0];
  firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

  var bgPlayer;
  var modalPlayer;
  var isPlaying = true;
  var isMuted = true;

  function onYouTubeIframeAPIReady() {
    bgPlayer = new YT.Player('youtube-bg-player', {
      videoId: '14FGjkrrXFk',
      playerVars: {
        autoplay: 1,
        controls: 0,
        showinfo: 0,
        rel: 0,
        loop: 1,
        playlist: '14FGjkrrXFk',
        mute: 1,
        playsinline: 1,
        modestbranding: 1,
        disablekb: 1,
      },
      events: {
        onReady: onPlayerReady,
      },
    });

    modalPlayer = new YT.Player('youtube-modal-player', {
      videoId: '14FGjkrrXFk',
      playerVars: {
        autoplay: 0,
        controls: 1,
        rel: 0,
      },
    });
  }

  function onPlayerReady(event) {
    event.target.playVideo();

    const btnPlayPause = document.getElementById('btnPlayPause');
    const iconPlay = document.getElementById('icon-play');
    const iconPause = document.getElementById('icon-pause');

    btnPlayPause.addEventListener('click', () => {
      if (isPlaying) {
        bgPlayer.pauseVideo();
        iconPause.classList.add('hidden');
        iconPause.classList.remove('block');
        iconPlay.classList.add('block');
        iconPlay.classList.remove('hidden');
      } else {
        bgPlayer.playVideo();
        iconPlay.classList.add('hidden');
        iconPlay.classList.remove('block');
        iconPause.classList.add('block');
        iconPause.classList.remove('hidden');
      }
      isPlaying = !isPlaying;
    });

    const btnMute = document.getElementById('btnMute');
    const iconMuted = document.getElementById('icon-muted');
    const iconUnmuted = document.getElementById('icon-unmuted');

    btnMute.addEventListener('click', () => {
      if (isMuted) {
        bgPlayer.unMute();
        iconMuted.classList.add('hidden');
        iconMuted.classList.remove('block');
        iconUnmuted.classList.add('block');
        iconUnmuted.classList.remove('hidden');
      } else {
        bgPlayer.mute();
        iconUnmuted.classList.add('hidden');
        iconUnmuted.classList.remove('block');
        iconMuted.classList.add('block');
        iconMuted.classList.remove('hidden');
      }
      isMuted = !isMuted;
    });
  }

  document.addEventListener('DOMContentLoaded', () => {
    const btnModal = document.getElementById('btnModal');
    const btnCloseModal = document.getElementById('btnCloseModal');
    const videoModal = document.getElementById('videoModal');

    btnModal.addEventListener('click', () => {
      videoModal.classList.remove('hidden');
      videoModal.classList.add('flex');
      setTimeout(() => videoModal.classList.remove('opacity-0'), 10);

      if (bgPlayer && typeof bgPlayer.pauseVideo === 'function') {
        bgPlayer.pauseVideo();
      }
      if (modalPlayer && typeof modalPlayer.playVideo === 'function') {
        modalPlayer.playVideo();
      }
    });

    btnCloseModal.addEventListener('click', () => {
      videoModal.classList.add('opacity-0');
      setTimeout(() => {
        videoModal.classList.add('hidden');
        videoModal.classList.remove('flex');
      }, 500);

      if (modalPlayer && typeof modalPlayer.pauseVideo === 'function') {
        modalPlayer.pauseVideo();
      }
      if (isPlaying && bgPlayer && typeof bgPlayer.playVideo === 'function') {
        bgPlayer.playVideo();
      }
    });
  });
</script>
